{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/bootstrap.sh && ${CLAUDE_PLUGIN_DATA}/.venv/bin/nephoscope-recorder session_start"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_DATA}/.venv/bin/nephoscope-recorder pre"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_DATA}/.venv/bin/nephoscope-permissions-hook"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_DATA}/.venv/bin/nephoscope-recorder post"
          }
        ]
      },
      {
        "matcher": "Bash|Grep|Read",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_DATA}/.venv/bin/nephoscope-output-scanner"
          }
        ]
      }
    ]
  }
}
